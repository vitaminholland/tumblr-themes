<!-- Shorten Notes Script by shythemes -->

<script>
var $container = $('.entries');
$container.find('.note-count').each(function(){
var n = $(this).html().split(' ')[0].replace(/,/g, '');
if (n > 999) {
n = Math.floor(n / 100) / 10;
$(this).text(n + 'k notes');
}
});
</script>


width: calc({text:Post Width} + 2px);
}
 
.entries-wrapper {
background: {color:Post Background};
border: 1px solid {color:Border};
width: {text:Post Width};
}

.entries img {
height: auto;
max-width: 100%;
}

.entries img {
height: auto;
max-width: 100%;
}

.npf_row img {
width: 100%;
}

.tmblr-full {
margin-bottom: 10px;
}

figure {
margin-bottom: 20px;
}

.npf_inst {
margin-bottom: 20px;
}

.npf-wrapper {
margin: 20px;
}

.npf-wrapper .tmblr-full {
display: flex;
}

.text-wrapper {
margin: 20px;
}

.read_more {
background: {color:Main Color};
border: 1px solid {color:Border};
border-radius: 5px;
color: white;
display: inline-block;
font-size: {select:Uppercase Font Size};
padding: 10px;
text-align: center;
text-transform: uppercase;
width: calc(100% - 22px);
}

.read_more:hover {
background: white;
color: {color:Main Color};
}

.vignette, #vignette {
opacity: 0;
}

.lightbox-image, #tumblr_lightbox img {
border-radius: 0!important;
box-shadow: none!important;
max-width: none;
}

.tmblr-lightbox, #tumblr_lightbox {
background-attachment: fixed;
background-image: url('https://i.imgur.com/7wF2zbK.png');
background-repeat: repeat;
}

.lightbox-caption, #tumblr_lightbox_caption {
visibility: hidden;
}

.text p {
margin-top: 0px;
}
 
.caption {
margin-top: 20px;
}

.caption p {
margin-top: 0px;
}

blockquote.tumblr_parent {
border: none;
border-bottom: 1px solid {color:Border};
margin: 0px;
margin-bottom: 20px;
padding: 0px;
}

blockquote.tumblr_parent:last-child {
border-bottom: 0px!important;
}

blockquote.user-reblog {
border: none;
margin: 0px;
padding: 0px;
}
 
.tumblr_avatar {
border: 1px solid {color:Border};
border-radius: 5px;
height: 30px;
margin-bottom: 20px;
width: 30px;
}
 
.tumblr_avatar img {
height: 30px;
width: 30px;
}
 
.user-image img {
height: 30px;
width: 30px;
}
 
a.tumblr_blog {
font-weight: bold;
margin-top: calc((30px - {select:Uppercase Font Size}) / 2.5);
display: inline-block;
position: absolute;
font-size: {select:Uppercase Font Size};
margin-left: 10px;
text-align: center;
text-transform: uppercase;
}

.message-wrapper {
background: {color:Pre Background};
border-bottom: 1px solid {color:Border};
margin: -20px;
margin-bottom: 0px;
padding-bottom: 35px;
width: calc(100% + 40px);
}

.message-info-wrapper {
height: 50px;
align-items: center;
display: flex;
justify-content: center;
flex-direction: row;
flex-wrap: wrap;
margin-top: -35px;
width: 100%;
}

.message {
padding: 20px;
}

.message p {
margin-block-start: 0em;
}

.message p:last-of-type {
margin-block-end: 0em;
}

.asker-wrapper {
height: 30px;
display: flex;
align-items: center;
flex-direction: row;
flex-wrap: wrap;
margin-bottom: -20px;
border-radius: 5px;
padding: 10px;
background: black;
}

.asker {
margin-right: 10px;
}

.asker img {
border-radius: 5px;
height: 30px;
width: 30px;
}

a.asker {
color: white;
margin-right: 0px;
}

a.asker:hover {
color: {color:Link Hover};
}

.asker-question {
font-size: {select:Uppercase Font Size};
text-transform: uppercase;
color: white;
}

.quote-wrapper {
background: {color:Pre Background};
border: 1px solid {color:Border};
display: flex;
align-items: center;
justify-content: space-between;
padding: 20px;
width: calc(100% - 42px);
}

.quote-icon {
background: {color:Main Color};
border-radius: 100px;
color: {color:Post Background};
font-size: 0.9rem;
height: 0.9rem;
padding: 10px;
width: 0.9rem;
}

.quote {
font-family: '{select:Heading Font}', sans-serif;
font-size: {select:Heading Font Size};
font-weight: bold;
margin-left: 15px;
text-align: right;
text-transform: lowercase;
}

.quote a.tumblr_blog {
font-size: {select:Uppercase Font Size};
font-weight: normal;
margin-top: 0px;
margin-left: 0px;
display: inline-block;
position: relative;
text-align: center;
text-transform: uppercase;
}

.website {
background: {color:Main Color};
border-radius: 5px;
color: {color:Post Background};
font-size: {select:Uppercase Font Size};
padding: 20px;
text-transform: uppercase;
}

.website a {
color: {color:Post Background};
}

.website a:hover {
color: {color:Link Hover};
}

.chat {
font-size: {select:Uppercase Font Size};
text-transform: uppercase;
}

.chat li {
list-style-type: none;
}

.chat li:nth-child(odd) {
background: {color:Main Color};
color: {color:Post Background};
padding: 10px;
}
 
.chat li:nth-child(even) {
background: {color:Chat Even Background};
color: {color:Main Color};
padding: 10px;
}

ul.chatwrap.npf_chat_processed {
font-size: {select:Uppercase Font Size};
text-transform: uppercase;
display: block;
list-style-type: none;
margin-block-start: 0em;
margin-block-end: 0em;
padding-inline-start: 0px;
unicode-bidi: isolate;
}

li.chatline:nth-child(odd) {
background: {color:Main Color};
color: {color:Post Background};
padding: 10px;
}
 
li.chatline:nth-child(even) {
background: {color:Chat Even Background};
color: {color:Main Color};
padding: 10px;
}

.audio iframe {
height: 85px;
width: 100%;
}

/** spotify fix by glenthemes **/

iframe[src*='open.spotify.com'][src*='track'], figure[data-npf*='open.spotify.com'][data-npf*='track']{
height: 85px!important;
margin-bottom: 0px;
}

figure {
display: flex;
width: 100%;
}

figcaption.npf-audio-wrapper {
width: 100%;
}

.npf-audio-wrapper {
--NPF-Audio-Buttons-Size: 1.4rem;
--NPF-Audio-Buttons-Color: #555555; 
--NPF-Audio-Buttons-Spacing: 1.3rem; 
--NPF-Audio-Image-Size: 85px;
--NPF-Audio-Image-Spacing: 0px; 
}

span.npf-audio-title {
font-weight: bold;
}

.npf-audio-background {
background-color: #f2f2f2; 
padding: 1.5rem;
}

video {
height: auto;
width: 100%;
}

.top-post-info {
border-bottom: 1px solid {color:Border};
padding: 20px;
}

.origins-icon {
display: flex;
flex-direction: row;
flex-wrap: wrap;
}

.origins-icon a {
margin-left: 10px;
background: {color:Main Color};
border-radius: 5px;
color: {color:Post Background};
font-size: 0.9rem;
font-variant: normal;
height: 0.9rem;
line-height: 1;
padding: 7px;
width: 0.9rem;
}

.origins-icon a:hover {
color: {color:Link Hover};
}

.pslr {
align-items: center;
display: flex;
justify-content: space-between;
overflow: hidden;
}

.top-notes {
border: 1px solid {color:Border};
background: {color:Post Background};
padding-left: 10px;
padding-right: 10px;
display: flex;
align-items: center;
border-radius: 5px;
height: 26.39px;
}

.pslr-a, .pslr-b {
align-items: center;
display: flex;
flex-direction: row;
text-transform: lowercase;
}

.pinned-post {
background: {color:Pin};
border-radius: 5px;
color: {color:Post Background};
font-size: {select:Uppercase Font Size};
font-variant: normal;
text-transform: uppercase;
height: 0.9rem;
line-height: 1;
padding: 7px;
margin-right: 10px;
}

.nitn-wrapper {
display: flex;
align-items: center;
}

.note-icon {
background: {color:Main Color};
border-radius: 5px;
color: white;
font-size: 0.9rem;
font-variant: normal;
height: 0.9rem;
line-height: 1;
padding: 7px;
width: 0.9rem;
margin-right: 10px;
}

.date {
font-size: {select:Uppercase Font Size};
background: {color:Main Color};
border-radius: 5px;
color: {color:Post Background};
font-variant: normal;
text-transform: uppercase;
height: 0.9rem;
line-height: 1;
padding: 7px;
margin-right: 10px;
}

.date a {
color: white;
}

.date a:hover {
color: {color:Link Hover};
}

.post-info {
border-top: 1px solid {color:Border};
padding: 20px;
}

.like-b {
display: inline-block;
margin-right: 0px;
position: relative;
}
 
.like-b .like_button iframe {
bottom: 0px;
left: 0px;
opacity: 0;
position: absolute;
right: 0px;
top: 0px;
}
 
.like-b .liked + .b {
color: {color:Like};
}

.reblog-b {
color: {color:Link};
display: inline-block;
margin-left: 10px;
}

.vsdt-wrapper {
margin: -3px;
margin-top: 10px;
}

.vsdt-wrapper span {
display: inline-block;
margin: 3px;
}

.show-tags {
margin-left: 10px;
}

.show-tags-content {
display: none;
}

.tags-title {
display: inline-block;
text-transform: lowercase;
}

.tags-title a {
-webkit-transition: all 0.5s ease;
-moz-transition: all 0.5s ease;
-o-transition: all 0.5s ease;
}
 
.tags-title:hover {
color: {color:Link Hover};
}
 
.tags {
text-transform: lowercase;
}

.tags-alternate {
display: inline-block;
text-transform: lowercase;
}

.tags, .tags-alternate {
span a {
background: linear-gradient(to right, {color:Main Color} 0 0);
background-repeat: no-repeat;
background-size: 100% 1px;
line-height: 150%;
background-position: bottom;
}
}

.permalink-info {
border-top: 1px solid {color:Border};
margin: -20px;
margin-top: 20px;
padding: 20px;
}

.permalink-info li {
list-style-type: none;
padding-left: 0px;
text-transform: lowercase;
}

ol.notes {
background: {color:Post Background};
border: 1px solid {color:Border};
margin-top: 20px;
padding: 10px;
text-align: left;
text-transform: lowercase;
}

ol.notes li {
list-style-type: none;
margin: 10px;
position: relative;
}

ol.notes img {
display:none;
}

ol.notes li:before {
font-family: "Phosphor";
speak: never;
font-style: normal;
font-weight: bold;
font-variant: normal;
text-transform: none;
line-height: 1;
letter-spacing: 0;
-webkit-font-smoothing: antialiased;
}

ol.notes li.reblog:before {
content:"\e094";
margin-right: 5px;
}

ol.notes li.like:before {
content:"\e2a8";
margin-right: 5px;
}

ol.notes li.original_post:before {
content:"\e3ae";
margin-right: 5px;
}

.more_notes_link {
background: {color:Main Color};
border-radius: 5px;
color: white;
display: inline-block;
padding: 5px 10px 5px 10px;
text-align: center;
}

.pagination {
align-items: center;
display: flex;
font-size: {select:Uppercase Font Size};
justify-content: space-between;
text-align: center;
text-transform: uppercase;
}

.navigation {
align-self: baseline;
display: flex;
}

.navigation a {
background: {color:Main Color};
border: 1px solid {color:Border};
color: {color:Post Background};
display: flex;
font-size: {select:Uppercase Font Size};
font-variant: normal;
align-items: center;
justify-content: center;
height: 10px;
padding: 10px;
}

.navigation a:hover {
background: {color:Post Background};
color: {color:Main Color};
}

.pages {
align-self: baseline;
display: flex;
align-items: center;
justify-content: center;
height: 10px;
background: {color:Main Color};
border: 1px solid {color:Border};
color: {color:Post Background};
font-size: {select:Uppercase Font Size};
padding: 10px;
text-transform: uppercase;
}

#top {
background: {color:Post Background};
border: 1px solid {color:Border};
bottom: 66px; 
border-radius: 5px;
color: {color:Link};
display: none;
font-size: 0.9rem;
font-variant: normal;
height: 0.9rem;
line-height: 1;
padding: 10px;
position: fixed;
right: 20px;
text-rendering: auto;
width: 0.9rem;
z-index: 1;
-webkit-transition: all 0.5s ease;
-moz-transition: all 0.5s ease;
-o-transition: all 0.5s ease;
}

#top:hover {
color: {color:Link Hover};
}

#credit {
bottom: 20px;
font-size: 0.9rem;
height: 36px;
position: fixed;
right: 20px;
text-transform: uppercase;
z-index: 1;
width: auto;
}

#credit a {
background: {color:Post Background};
border: 1px solid {color:Border};
color: {color:Link};
display: inline-block;
border-radius: 5px;
font-size: 0.9rem;
font-variant: normal;
height: 0.9rem;
line-height: 1;
padding: 10px;
width: 0.9rem;
}

#credit a:hover  {
color: {color:Link Hover};
}

{CustomCSS}
    
</style>
    
</head>

<body>

<a class="controls-button" title="Tumblr Controls"><i class="ri-equalizer-2-fill"></i></a>

<div id="container">

<div id="left">

<div class="sidebar-image">

<div class="iil-wrapper">

<div class="icon-image"><img src="{image:Icon Image}"/></div>

<div class="main-links">
<a href="/" title="Home"><i class="ri-home-4-line"></i></a>
{block:AskEnabled}<a href="/ask" title="Ask"><i class="ri-mail-unread-line"></i></a>{/block:AskEnabled}
<a href="/archive" title="Archive"><i class="ph-bold ph-archive"></i></a>
</div>
    
</div>

</div>

<div class="sidebar-wrapper">

<div class="blog-title">{text:Title}</div>

{block:Description}<div class="description">{Description}</div>{/block:Description}

</div>

</div>

<div id="posts">

{block:Posts}

<div class="entries" id="{PostID}" post-type="{PostType}">

<div class="entries-wrapper">

{block:IndexPage}
<div class="top-post-info">
<div class="pslr">
<div class="pslr-a">
{block:PinnedPostLabel}<div class="pinned-post"><i class="ri-bookmark-3-line" style="font-size: 0.9rem;margin-right: 10px;"></i>{PinnedPostLabel}</div>{/block:PinnedPostLabel}
<div class="nitn-wrapper">
<div class="note-icon"><i class="ri-line-chart-line"></i></div>
<div class="top-notes">
<a href="{Permalink}"><div class="note-count">{NoteCountWithLabel}</div></a>
</div>
</div>
</div>
<div class="pslr-b">
<div class="origins-icon">
{block:RebloggedFrom}<a  href="{ReblogParentURL}" title="Reblogged Via {ReblogParentName}"><i class="ri-arrow-left-down-box-line"></i></a>{/block:RebloggedFrom}
{block:RebloggedFrom}<a href="{ReblogRootURL}" title="Originally Posted By {ReblogRootName}"><i class="ri-git-fork-line"></i></a>{/block:RebloggedFrom}
</div>
</div>
</div>
</div>
{/block:IndexPage}

{block:Text}
{block:NotReblog}
<div class="npf-wrapper">
{block:Title}
<h1>{Title}</h1>
{/block:Title}
{Body}
</div>
{/block:NotReblog}
{block:RebloggedFrom}
<div class="text-wrapper">
{block:Title}
<h1>{Title}</h1>
{/block:Title}
<div class="text">
{Body}
</div>
</div>
{/block:RebloggedFrom}
{/block:Text}

{block:Answer}
<div class="text-wrapper">
<div class="message-wrapper">
<div class="message">{Question}</div>
</div>
<div class="message-info-wrapper">
<div class="asker-wrapper">
<div class="asker"><img src="{AskerPortraitURL-128}"/></div><div class="asker-question"><i class="ri-chat-follow-up-line"></i> {Asker} sent a message</div>
</div>
</div>
<div class="caption">
{Answer}
</div>
</div>
{/block:Answer}

{block:Quote}
<div class="text-wrapper">
<div class="quote-wrapper">
<div class="quote-icon"><i class="ri-double-quotes-l"></i></div>
<div class="quote">
"{Quote}</i>" 
{block:Source}
<br><br>
<font style="font-family: '{select:Body Font}', sans-serif;font-size: {select:Uppercase Font Size};font-style: normal;font-weight: normal;text-transform: uppercase;">
— {Source}
</font>
{/block:Source}
</div>
</div>
</div>
{/block:Quote}

{block:Link}
<div class="text-wrapper">
{block:Thumbnail}
<img src="{Thumbnail}" style="border-radius: 5px;margin-bottom: 10px;"/>
{/block:Thumbnail}
<div class="website"><i class="ri-external-link-line" style="margin-right: 10px;"></i><a href="{URL}" target="_blank">{Name}{block:Excerpt}<br><br>{Excerpt}{/block:Excerpt}
</a></div>
{block:Description}
<div class="caption">
{Description}
</div>
{/block:Description}
</div>
{/block:Link}

{block:Chat}
<div class="text-wrapper">
<div class="chat">
{block:Title}
<h1>{Title}</h1>
{/block:Title}
{block:Lines}
<li>{block:Label}{Label}{/block:Label}
{Line}
</li>
{/block:Lines}
</div>
</div>
{/block:Chat}

{block:Audio}
<div class="text-wrapper">
<div class="audio">
{AudioEmbed}
</div>
{block:Caption}
<div class="caption">{Caption}</div>
{/block:Caption}
</div>
{/block:Audio}

{block:Photo}
<a href="#" onclick="Tumblr.Lightbox.init([{ width: {PhotoWidth-HighRes}, height: {PhotoHeight-HighRes}, low_res: '{PhotoURL-HighRes}', high_res: '{PhotoURL-HighRes}' }]); $('body').toggleClass('tumblr_lightbox_active'); return false"><img src="{PhotoURL-HighRes}"></a>
{block:Caption}
<div class="text-wrapper">
<div class="caption">{Caption}</div>
</div>
{/block:Caption}
{/block:Photo}

{block:Photoset}
<div class="photo-slideshow" id="photoset_{PostID}" data-layout="{PhotosetLayout}">{block:Photos}<div class="photo-data"><div class="pxu-photo"><img src="{PhotoURL-500}" width="{PhotoWidth-500}" height="{PhotoHeight-500}" data-highres="{PhotoURL-HighRes}" data-width="{PhotoWidth-HighRes}" data-height="{PhotoHeight-HighRes}"></div><a class="tumblr-box" rel="post-{PostID}" href="{PhotoURL-HighRes}"></a></div>{/block:Photos}</div>
{block:Caption}
<div class="text-wrapper">
<div class="caption">{Caption}</div>
</div>
{/block:Caption}
{/block:Photoset}

{block:Video}
<div class="text-wrapper">
<div class="video">
{Video-500}
</div>
{block:Caption}
<div class="caption">{Caption}</div>
{/block:Caption}
</div>
{/block:Video}

{block:Date}
<div class="post-info">
<div class="pslr">
<div class="pslr-a">{block:IndexPage}{block:Date}<div class="date"><a href="{Permalink}">{ShortMonth} {DayOfMonth}, {Year}</a></div>{/block:Date}{/block:IndexPage}
</div>
<div class="pslr-b">
<a class="like-b" href="#">{LikeButton}<div class="b"><i class="ri-heart-line"></i></div></a>
<a class="reblog-b" href="{ReblogURL}" target="_blank"><i class="ri-refresh-line"></i></a>
{block:IfHideTags}{block:HasTags}<a class="show-tags"><i class="ri-hashtag"></i></a>{/block:HasTags}{/block:IfHideTags}
</div>
</div>

{block:IfHideTags}
{block:HasTags}
<div class="show-tags-content">
<div class="vsdt-wrapper">
<div class="tags">
{block:Tags}
<span><a href="{TagURL}">{Tag}</a></span>
{/block:Tags}
</div>
</div>
</div>
{/block:HasTags}
{/block:IfHideTags}
{block:IfShowTags}
{block:HasTags}
<div class="vsdt-wrapper">
<div class="tags-alternate">
{block:Tags}
<span><a href="{TagURL}">{Tag}</a></span>
{/block:Tags}
</div>
</div>
{/block:HasTags}
{/block:IfShowTags}

{block:Permalink}
<div class="permalink-info">
{block:PinnedPostLabel}<li><i class="ri-pushpin-2-line" style="margin-right: 5px;"></i>{PinnedPostLabel}</li>{block:PinnedPostLabel}
<li><i class="ri-calendar-todo-line" style="margin-right: 5px;"></i>Posted On {Month} {DayOfMonth}, {Year}</li>
{block:RebloggedFrom}<li><i class="ri-arrow-left-down-box-line" style="margin-right: 5px;"></i><a  href="{ReblogParentURL}">Reblogged Via {ReblogParentName}</a></li>{/block:RebloggedFrom}
{block:RebloggedFrom}<li><i class="ri-quill-pen-line" style="margin-right: 5px;"></i><a href="{ReblogRootURL}">Originally Posted By {ReblogRootName}</a></li>{/block:RebloggedFrom}
{block:NoteCount}<li><i class="ri-discuss-line" style="margin-right: 5px;"></i>With <a href="{Permalink}">{NoteCountWithLabel}</a></li>{/block:NoteCount}
{block:ContentSource}<li><i class="ri-code-s-line" style="margin-right: 5px;"></i>Sourced From <a href="{SourceURL}">{SourceTitle}</a></li>{/block:ContentSource}
</div>
{/block:Permalink}
</div>
{/block:Date}

</div>

{block:PostNotes}
{PostNotes}
{/block:PostNotes}

</div>

{/block:Posts}

{block:Pagination}
<div class="pagination">
{block:PreviousPage}
<div class="navigation">
<a href="{PreviousPage}"><i class="ri-contract-left-line" style="margin-right: 5px;"></i>Prev</a>
</div>
{/block:PreviousPage}
<div class="pages">
{CurrentPage} / {TotalPages} Pages
</div>
{block:NextPage}
<div class="navigation">
<a href="{NextPage}">Next<i class="ri-contract-right-line" style="margin-left: 5px;"></i></a> 
</div>
{/block:NextPage}
</div>
{/block:Pagination}

</div>

<div id="right">

<div class="box"><i class="ri-add-line" style="color: {color:Main Color};"></i> <b>explore and about me</div>

<div class="box">

<div class="more-links">
{block:SubmissionsEnabled}{block:ifSubmitLink}<a href="/submit"><div class="ml-icon"><i class="ph-bold ph-tray-arrow-up"></i></div>Submit</a>{/block:ifSubmitLink}{/block:SubmissionsEnabled}

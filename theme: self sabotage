align-items: center;
display: flex;
padding: 20px;
}

.asker {
height: 48px;
margin-right: 20px;
width: 48px;
}

.asker img {
border-radius: 5px;
height: 48px;
width: 48px;
}

a.asker {
margin-right: 0px;
}

.asker-question {
font-size: {select:Uppercase Font Size};
text-transform: uppercase;
width: calc(100% - 68px);
}

.message {
padding: 20px;
}

.message p {
margin-block-start: 0em;
}

.message p:last-of-type {
margin-block-end: 0em;
}

.quote-wrapper {
width: 100%;
}

.quote-icon {
background: {color:Chat Even Background};
border-radius: 100px;
color: {color:Main Color};
font-size: 0.9rem;
height: 0.9rem;
margin-left: auto;
margin-right: auto;
margin-top: -17.195px;
padding: 10px;
width: 0.9rem;
}

.quote {
border: 1px solid {color:Border};
border-radius: 5px;
font-family: 'Playfair Display', serif;
font-size: 1.2rem;
font-weight: bold;
padding: 10px;
padding-bottom: 26.4px;
text-align: center;
}

.quote a.tumblr_blog {
font-size: {select:Uppercase Font Size};
font-weight: normal;
margin-top: 0px;
margin-left: 0px;
display: inline-block;
position: relative;
text-align: center;
text-transform: uppercase;
}

.website {
background: {color:Main Color};
border-radius: 5px;
color: {color:Post Background};
font-size: {select:Uppercase Font Size};
padding: 20px;
text-transform: uppercase;
}

.website a {
color: {color:Post Background};
}

.website a:hover {
color: {color:Link Hover};
}

.chat {
font-size: {select:Uppercase Font Size};
text-transform: uppercase;
}

.chat li {
list-style-type: none;
}

.chat li:nth-child(odd) {
background: {color:Main Color};
color: {color:Post Background};
padding: 10px;
}
 
.chat li:nth-child(even) {
background: {color:Chat Even Background};
color: {color:Main Color};
padding: 10px;
}

ul.chatwrap.npf_chat_processed {
font-size: {select:Uppercase Font Size};
text-transform: uppercase;
display: block;
list-style-type: none;
margin-block-start: 0em;
margin-block-end: 0em;
padding-inline-start: 0px;
unicode-bidi: isolate;
}

li.chatline:nth-child(odd) {
background: {color:Main Color};
color: {color:Post Background};
padding: 10px;
}
 
li.chatline:nth-child(even) {
background: {color:Chat Even Background};
color: {color:Main Color};
padding: 10px;
}

.audio iframe {
height: 85px;
width: 100%;
}

/** spotify fix by glenthemes **/

iframe[src*='open.spotify.com'][src*='track'], figure[data-npf*='open.spotify.com'][data-npf*='track']{
height: 85px!important;
margin-bottom: 0px;
}

figure {
display: flex;
width: 100%;
}

figcaption.npf-audio-wrapper {
width: 100%;
}

.npf-audio-wrapper {
--NPF-Audio-Buttons-Size: 1.4rem;
--NPF-Audio-Buttons-Color: #555555; 
--NPF-Audio-Buttons-Spacing: 1.3rem; 
--NPF-Audio-Image-Size: 85px;
--NPF-Audio-Image-Spacing: 0px; 
}

span.npf-audio-title {
font-weight: bold;
}

.npf-audio-background {
background-color: #f2f2f2; 
padding: 1.5rem;
}

video {
height: auto;
width: 100%;
}

.post-info {
border-top: 1px solid {color:Border};
padding: 20px;
}

.pslr {
align-items: center;
display: flex;
justify-content: space-between;
overflow: hidden;
}

.pslr-a, .pslr-b {
font-size: {select:Uppercase Font Size};
text-transform: uppercase;
}

.pinned-post {
color: {color:Pin};
display: inline-block;
margin-right: 10px;
}

.date {
display: inline-block;
margin-right: 10px;
}

.like-b {
display: inline-block;
margin-right: 0px;
position: relative;
}
 
.like-b .like_button iframe {
bottom: 0px;
left: 0px;
opacity: 0;
position: absolute;
right: 0px;
top: 0px;
}
 
.like-b .liked + .b {
color: {color:Like};
}

.reblog-b {
color: {color:Link};
display: inline-block;
margin-left: 10px;
}

.vsdt-wrapper {
margin-top: 10px;
}

.vsdt-wrapper span {
background: {color:Main Color};
border-radius: 5px;
display: inline-block;
padding: 3px;
}

.vsdt-wrapper span a {
color: {color:Post Background};
}

.vsdt-wrapper span a:hover {
color: {color:Link Hover};
}

.tags-title {
font-size: {select:Uppercase Font Size};
text-transform: uppercase;
display: inline-block;
background: {color:Post Background};
border: 1px solid {color:Border};
border-radius: 5px;
padding: 5px 10px 5px 10px;
align-items: center;
-webkit-transition: all 0.5s ease;
-moz-transition: all 0.5s ease;
-o-transition: all 0.5s ease;
-webkit-transition: all 0.5s ease;
-moz-transition: all 0.5s ease;
-o-transition: all 0.5s ease;
}
 
.tags {
margin: -5px;
margin-top: 5px;
text-transform: lowercase;
}

.tags-alternate {
margin: -5px;
text-transform: lowercase;
}

.tags-alternate {
margin: -5px;
text-transform: lowercase;
}

.tags a, .tags-alternate a {
background: {color:Main Color};
display: inline-block;
margin: 5px;
color: white;
border-radius: 5px;
padding: 5px;
}

.tags a:hover, .tags-alternate a:hover {
color: {color:Link Hover};
}

.permalink-info {
border-top: 1px solid {color:Border};
margin: -20px;
margin-top: 20px;
padding: 20px;
}

.permalink-info li {
list-style-type: none;
font-size: {select:Uppercase Font Size};
padding-left: 0px;
text-transform: uppercase;
}

ol.notes {
background: {color:Post Background};
border: 1px solid {color:Border};
margin-top: 20px;
padding: 10px;
text-align: left;
text-transform: lowercase;
}

ol.notes li {
list-style-type: none;
margin: 10px;
position: relative;
}

ol.notes img {
display:none;
}

ol.notes li:before {
font-family: "Phosphor";
speak: never;
font-style: normal;
font-weight: bold;
font-variant: normal;
text-transform: none;
line-height: 1;
letter-spacing: 0;
-webkit-font-smoothing: antialiased;
}

ol.notes li.reblog:before {
content:"\e094";
margin-right: 5px;
}

ol.notes li.like:before {
content:"\e2a8";
margin-right: 5px;
}

ol.notes li.original_post:before {
content:"\e3ae";
margin-right: 5px;
}

.more_notes_link {
background: {color:Main Color};
border-radius: 5px;
color: white;
display: inline-block;
padding: 5px 10px 5px 10px;
text-align: center;
}

.pagination {
align-items: center;
display: flex;
font-size: {select:Uppercase Font Size};
justify-content: space-between;
text-align: center;
text-transform: uppercase;
}

.navigation {
align-self: baseline;
display: flex;
}

.navigation a {
background: {color:Main Color};
border-radius: 100px;
border: 1px solid {color:Border};
color: {color:Post Background};
display: inline-block;
font-size: 0.9rem;
font-variant: normal;
height: 0.9rem;
line-height: 1;
padding: 10px;
text-rendering: auto;
width: 0.9rem;
}

.navigation a:hover {
background: {color:Post Background};
color: {color:Main Color};
}

.pages {
align-self: baseline;
display: flex;
font-size: {select:Uppercase Font Size};
text-transform: uppercase;
}

#top {
background: {color:Post Background};
border: 1px solid {color:Border};
bottom: 66px; 
border-radius: 5px;
color: {color:Link};
display: none;
font-size: 0.9rem;
font-variant: normal;
height: 0.9rem;
line-height: 1;
padding: 10px;
position: fixed;
right: 20px;
text-rendering: auto;
width: 0.9rem;
z-index: 1;
-webkit-transition: all 0.5s ease;
-moz-transition: all 0.5s ease;
-o-transition: all 0.5s ease;
}

#top:hover {
color: {color:Link Hover};
}

#credit {
bottom: 20px;
font-size: 0.9rem;
height: 36px;
position: fixed;
right: 20px;
text-transform: uppercase;
z-index: 1;
width: auto;
}

#credit a {
background: {color:Post Background};
border: 1px solid {color:Border};
color: {color:Link};
display: inline-block;
border-radius: 5px;
font-size: 0.9rem;
font-variant: normal;
height: 0.9rem;
line-height: 1;
padding: 10px;
width: 0.9rem;
}

#credit a:hover  {
color: {color:Link Hover};
}

{CustomCSS}
    
</style>
    
</head>

<body>

<a class="controls-button" title="Tumblr Controls"><i class="ri-equalizer-2-fill"></i></a>

<div id="container">

<div id="posts">

{block:Posts}

<div class="entries" id="{PostID}" post-type="{PostType}">

<div class="eie-wrapper">

{block:NotReblog} 
<div class="entries-info">
<a href="/" title="Original Poster">
<img src="{PortraitURL-128}"/>
</div>
</a>
{/block:NotReblog}

{block:RebloggedFrom}
<div class="entries-info">
<a href="{ReblogParentURL}" title="Reblogged From"><img src="{ReblogParentPortraitURL-128}"/></a>
</div>
{/block:RebloggedFrom}

<div class="ewn-wrapper">

<div class="entries-wrapper">

{block:Text}
{block:NotReblog}
<div class="npf-wrapper">
{block:Title}
<h1>{Title}</h1>
{/block:Title}
{Body}
</div>
{/block:NotReblog}
{block:RebloggedFrom}
<div class="text-wrapper">
{block:Title}
<h1>{Title}</h1>
{/block:Title}
<div class="text">
{Body}
</div>
</div>
{/block:RebloggedFrom}
{/block:Text}

{block:Answer}
<div class="text-wrapper">
<div class="message-wrapper">
<div class="message-info-wrapper">
<div class="asker"><img src="{AskerPortraitURL-128}"/></div><div class="asker-question"><i class="ri-chat-follow-up-line"></i> {Asker} <br> sent a message:</div>
</div>
<div class="message">{Question}</div>
</div>
<div class="caption">
{Answer}
</div>
</div>
{/block:Answer}

{block:Quote}
<div class="text-wrapper">
<div class="quote-wrapper">
<div class="quote">
"{Quote}</i>" 
{block:Source}
<br><br>
<font style="font-family: '{select:Body Font}', sans-serif;font-size: {select:Uppercase Font Size};font-style: normal;font-weight: normal;text-transform: uppercase;">
— {Source}
</font>
{/block:Source}
</div>
<div class="quote-icon"><i class="ri-double-quotes-l" style="vertical-align: top;"></i></div>
</div>
</div>
{/block:Quote}

{block:Link}
<div class="text-wrapper">
{block:Thumbnail}
<img src="{Thumbnail}" style="border-radius: 5px;margin-bottom: 10px;"/>
{/block:Thumbnail}
<div class="website"><i class="ri-external-link-line" style="margin-right: 10px;"></i><a href="{URL}" target="_blank">{Name}{block:Excerpt}<br><br>{Excerpt}{/block:Excerpt}
</a></div>
{block:Description}
<div class="caption">
{Description}
</div>
{/block:Description}
</div>
{/block:Link}

{block:Chat}
<div class="text-wrapper">
<div class="chat">
{block:Title}
<h1>{Title}</h1>
{/block:Title}
{block:Lines}
<li>{block:Label}{Label}{/block:Label}
{Line}
</li>
{/block:Lines}
</div>
</div>
{/block:Chat}

{block:Audio}
<div class="text-wrapper">
<div class="audio">
{AudioEmbed}
</div>
{block:Caption}
<div class="caption">{Caption}</div>
{/block:Caption}
</div>
{/block:Audio}

{block:Photo}
<a href="#" onclick="Tumblr.Lightbox.init([{ width: {PhotoWidth-HighRes}, height: {PhotoHeight-HighRes}, low_res: '{PhotoURL-HighRes}', high_res: '{PhotoURL-HighRes}' }]); $('body').toggleClass('tumblr_lightbox_active'); return false"><img src="{PhotoURL-HighRes}"></a>
{block:Caption}
<div class="text-wrapper">
<div class="caption">{Caption}</div>
</div>
{/block:Caption}
{/block:Photo}

{block:Photoset}
<div class="photo-slideshow" id="photoset_{PostID}" data-layout="{PhotosetLayout}">{block:Photos}<div class="photo-data"><div class="pxu-photo"><img src="{PhotoURL-500}" width="{PhotoWidth-500}" height="{PhotoHeight-500}" data-highres="{PhotoURL-HighRes}" data-width="{PhotoWidth-HighRes}" data-height="{PhotoHeight-HighRes}"></div><a class="tumblr-box" rel="post-{PostID}" href="{PhotoURL-HighRes}"></a></div>{/block:Photos}</div>
{block:Caption}
<div class="text-wrapper">
<div class="caption">{Caption}</div>
</div>
{/block:Caption}
{/block:Photoset}

{block:Video}
<div class="text-wrapper">
<div class="video">
{Video-500}
</div>
{block:Caption}
<div class="caption">{Caption}</div>
{/block:Caption}
</div>
{/block:Video}

{block:Date}
<div class="post-info">
<div class="pslr">
<div class="pslr-a">{block:PinnedPostLabel}<div class="pinned-post"><i class="ri-bookmark-3-line"></i></div>{/block:PinnedPostLabel}<div class="date">
<i class="ri-time-line" style="margin-right: 5px;"></i><a href="{Permalink}">{Timeago}</a>
</div>{block:IndexPage}{block:NoteCount}<i class="ri-line-chart-line" style="margin-right: 5px;"></i><a href="{Permalink}" class="note-count">{NoteCountWithLabel}</a>{/block:NoteCount}{/block:IndexPage}
</div>
<div class="pslr-b">
<a class="like-b" href="#">{LikeButton}<div class="b"><i class="ri-heart-line"></i></div></a>
<a class="reblog-b" href="{ReblogURL}" target="_blank"><i class="ri-refresh-line"></i></i></a>
</div>
</div>

{block:IfHideTags}
{block:HasTags}
<div class="vsdt-wrapper">
<a class="tags-title"><i class="ri-arrow-down-s-line" style="color: {color:Main Color};margin-right: 5px;"></i>Show Tags</a>
<div class="tags">
{block:Tags}
<a href="{TagURL}"><font style="display: flex;align-items: center;"><i class="ri-heart-3-line" style="margin-right: 5px;"></i>{Tag}</font></a>
{/block:Tags}
</div>
</div>
{/block:HasTags}
{/block:IfHideTags}
{block:IfShowTags}
{block:HasTags}
<div class="vsdt-wrapper">
<div class="tags-alternate">
{block:Tags}
<a href="{TagURL}"><font style="display: flex;align-items: center;"><i class="ri-heart-3-line" style="margin-right: 5px;"></i>{Tag}</font></a>
{/block:Tags}
</div>
</div>
{/block:HasTags}
{/block:IfShowTags}

{block:Permalink}
<div class="permalink-info">
{block:PinnedPostLabel}<li><i class="ri-pushpin-2-line" style="margin-right: 5px;"></i>{PinnedPostLabel}</li>{block:PinnedPostLabel}
<li><i class="ri-calendar-todo-line" style="margin-right: 5px;"></i>Posted On {Month} {DayOfMonth}, {Year}</li>
{block:RebloggedFrom}<li><i class="ri-arrow-left-down-box-line" style="margin-right: 5px;"></i><a  href="{ReblogParentURL}">Reblogged Via {ReblogParentName}</a></li>{/block:RebloggedFrom}
{block:RebloggedFrom}<li><i class="ri-quill-pen-line" style="margin-right: 5px;"></i><a href="{ReblogRootURL}">Originally Posted By {ReblogRootName}</a></li>{/block:RebloggedFrom}
{block:NoteCount}<li><i class="ri-discuss-line" style="margin-right: 5px;"></i>With <a href="{Permalink}">{NoteCountWithLabel}</a></li>{/block:NoteCount}
{block:ContentSource}<li><i class="ri-code-s-line" style="margin-right: 5px;"></i>Sourced From <a href="{SourceURL}">{SourceTitle}</a></li>{/block:ContentSource}
</div>
{/block:Permalink}
</div>
{/block:Date}

</div>

{block:PostNotes}
{PostNotes}
{/block:PostNotes}

</div>

</div>

</div>

{/block:Posts}

{block:Pagination}
<div class="pagination">
{block:PreviousPage}
<div class="navigation">
<a href="{PreviousPage}"><i class="ri-contract-left-line"></i></a>
</div>
{/block:PreviousPage}
<div class="pages">
{CurrentPage} / {TotalPages} Pages
</div>
{block:NextPage}
<div class="navigation">
<a href="{NextPage}"><i class="ri-contract-right-line"></i></a> 
</div>
{/block:NextPage}
</div>
{/block:Pagination}

</div>

<div id="ui-wrapper">

<!-- Start of First Half -->

<div id="user-information">

<div class="blog-title">{text:Title}</div>

<div class="sidebar-image"><img src="{image:Sidebar Image}"/></div>

<div class="aq-wrapper">

<div class="aq-icon"><i class="ri-single-quotes-l"></i></div>

<div class="actual-quote">{text:Quote}</div>

</div>

<div class="lp-wrapper">

<div class="home">
<a href="/">Home</a>
</div>

<div class="button-icon"><a class="show-sidebar" title="About @{Name}"><i class="ri-compass-3-line"></i></a></div>

</div>

</div>

<!-- End of First Half -->

<div class="sidebar-content">

{block:Description}<div class="description">{Description}</div>{/block:Description}

<!-- Start of Short Updates -->

<div class="short-updates">
<li><i class="ri-headphone-line" style="color: {color:Main Color};margin-right: 10px;"></i>{text:Listening To}</li>
<li><i class="ri-book-marked-line" style="color: {color:Main Color};margin-right: 10px;"></i>{text:Currently Reading}</li>
<li><i class="ri-tv-line" style="color: {color:Main Color};margin-right: 10px;"></i>{text:Currently Watching}</li>
<li><i class="ri-file-check-line" style="color: {color:Main Color};margin-right: 10px;"></i>{text:To Do List}</li>
</div>

<!-- End of Short Updates -->

<div class="links">
{block:AskEnabled}<a href="/contact"><div class="link-icon"><i class="ri-mail-unread-line"></i></div>Ask</a>{/block:AskEnabled}
{block:SubmissionsEnabled}{block:ifSubmitLink}<a href="/submit"><div class="link-icon"><i class="ri-image-add-line"></i></div>Submit</a>{/block:ifSubmitLink}{/block:SubmissionsEnabled}
{block:ifLink1URL}<a href="{text:Link 1 URL}"><div class="link-icon"><i class="ri-planet-line"></i></div>{text:Link 1 Name}</a>{/block:ifLink1URL}
{block:ifLink2URL}<a href="{text:Link 2 URL}"><div class="link-icon"><i class="ri-sailboat-line"></i></div>{text:Link 2 Name}</a>{/block:ifLink2URL}
{block:ifLink3URL}<a href="{text:Link 3 URL}"><div class="link-icon"><i class="ri-bowl-line"></i></div>{text:Link 3 Name}</a>{/block:ifLink3URL}
<a href="/archive"><div class="link-icon"><i class="ri-archive-line"></i></div>Archive</a>
</div>

</div>

</div>

</div>

{block:IfBackToTop}<div id="top"><i class="ri-skip-up-line"></i></div>{/block:IfBackToTop}

<!-- Start of Theme Credit -->

<div id="credit" title="ghcstfaec"><a href="https://ghcstfaec.tumblr.com/"><i class="ri-moon-clear-line"></i></a></div>

<!-- End of Theme Credit -->  

</body>

<!-- Shorten Notes Script by shythemes -->

<script>
var $container = $('.entries');
$container.find('.note-count').each(function(){
var n = $(this).html().split(' ')[0].replace(/,/g, '');
if (n > 999) {
n = Math.floor(n / 100) / 10;
$(this).text(n + 'k notes');
}
});
</script>

</html>
